# ============================================================
# TruthMarket — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose this to the client/browser.
# Used only in API routes (server-side). Has full DB access bypassing RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Paystack ─────────────────────────────────────────────────
# Found in: Paystack Dashboard → Settings → API Keys & Webhooks
# Use TEST keys during development, LIVE keys on production only.
PAYSTACK_SECRET_KEY=sk_test_your-secret-key-here
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your-public-key-here

# ── Polygon / Alchemy ─────────────────────────────────────────
# Used for reading chain state (balance checks, event listening)
# Get a free key at: https://alchemy.com
NEXT_PUBLIC_ALCHEMY_KEY=your-alchemy-api-key-here

# ── Smart Contract Addresses ──────────────────────────────────
# Set after deploying TruthMarket.sol and tNGN.sol to Polygon Amoy (testnet)
NEXT_PUBLIC_TRUTH_MARKET_ADDRESS=0x...
NEXT_PUBLIC_TNGN_ADDRESS=0x...

# ── WalletConnect (RainbowKit fallback only) ──────────────────
# Get a project ID at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_ID=your-walletconnect-project-id

# ── AWS KMS (Phase 3 — Key Derivation) ───────────────────────
# Set up AFTER creating a KMS Customer Master Key in AWS Console.
# IAM role must have kms:GenerateMac permission on this key.
# Leave blank during Phase 2 testing — mock wallet addresses are used.
AWS_REGION=eu-west-1
AWS_KMS_KEY_ID=your-kms-key-id-here
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here

# ── Internal Security ─────────────────────────────────────────
# Random secret to protect internal cron/Inngest endpoints.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# Admin API secret for the withdrawal approval dashboard.
# Generate with: openssl rand -hex 32
ADMIN_SECRET=your-admin-secret-here

# ── Inngest ───────────────────────────────────────────────────────────────
# Get from https://app.inngest.com after creating an app
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ── Football Data Oracle ──────────────────────────────────────────────────
# Get a free key from https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your-football-data-api-key

# ── App URL ───────────────────────────────────────────────────────────────
# Set to your production URL for Inngest job callbacks
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Admin Secret (also set as NEXT_PUBLIC for client-side admin panel) ────
# This exposes the admin gate to the client — OK for internal use.
# Never expose SUPABASE_SERVICE_ROLE_KEY this way.
NEXT_PUBLIC_ADMIN_SECRET=your-admin-secret-here
NEXT_PUBLIC_CRON_SECRET=your-cron-secret-here
